# ============================================================
# SIAGA Backend — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# Server
PORT=3000
NODE_ENV=development
# TRUST_PROXY (opsional):
# - development default: false (abaikan X-Forwarded-* untuk identity)
# - production default: 1 (anggap ada 1 reverse proxy terpercaya)
# Nilai yang didukung: true/false, angka hop (mis. 1, 2), atau daftar subnet/ip Express
# TRUST_PROXY=1

# Supabase
SUPABASE_URL=https://project.supabase.co
SUPABASE_ANON_KEY=supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=supabase-service-role-key

# JWT (jika pakai custom JWT selain Supabase Auth)
JWT_SECRET=jwt-secret-min-32-chars

# CORS — URL frontend (Expo dev server)
CORS_ORIGIN=http://localhost:8081

# Rate Limiter debug logging
RATE_LIMIT_DEBUG=false

# publicRead — trusted IP bucket for /api/reports (public GETs), /api/area-status, /api/info
RATE_LIMIT_PUBLIC_READ_WINDOW_MS=900000
RATE_LIMIT_PUBLIC_READ_MAX_DEV=2000
RATE_LIMIT_PUBLIC_READ_MAX_PROD=1500

# publicAuth — trusted IP bucket for register/login/forgot-password
RATE_LIMIT_PUBLIC_AUTH_WINDOW_MS=900000
RATE_LIMIT_PUBLIC_AUTH_MAX_DEV=150
RATE_LIMIT_PUBLIC_AUTH_MAX_PROD=80

# authRefresh — trusted IP bucket for /api/auth/refresh
RATE_LIMIT_AUTH_REFRESH_WINDOW_MS=900000
RATE_LIMIT_AUTH_REFRESH_MAX_DEV=300
RATE_LIMIT_AUTH_REFRESH_MAX_PROD=150

# upload — authenticated user bucket with trusted-IP fallback for /api/upload
RATE_LIMIT_UPLOAD_WINDOW_MS=900000
RATE_LIMIT_UPLOAD_MAX_DEV=200
RATE_LIMIT_UPLOAD_MAX_PROD=120

# bmkg — trusted IP bucket for /api/bmkg/*
RATE_LIMIT_BMKG_WINDOW_MS=900000
RATE_LIMIT_BMKG_MAX_DEV=600
RATE_LIMIT_BMKG_MAX_PROD=300

# authenticatedGeneral — authenticated user bucket with trusted-IP fallback for protected routes
RATE_LIMIT_AUTHENTICATED_GENERAL_WINDOW_MS=900000
RATE_LIMIT_AUTHENTICATED_GENERAL_MAX_DEV=1600
RATE_LIMIT_AUTHENTICATED_GENERAL_MAX_PROD=1200
